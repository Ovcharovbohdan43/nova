# Environment variables — copy to apps/web/.env.local

# PostgreSQL (Supabase) — Dashboard → Project Settings → Database → Connection string → URI
# If waitlist fails with user `build@localhost`, a system DATABASE_URL is overriding this file.
# Fix: unset DATABASE_URL in shell, or rely on @nova/database load-env (loads .env.local with override).
# Use direct connection (port 5432) for local dev and migrations
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Public app URL (Railway preview or custom domain)
# Public site URL (https:// is optional; added automatically if omitted)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: analytics
# NEXT_PUBLIC_POSTHOG_KEY=
