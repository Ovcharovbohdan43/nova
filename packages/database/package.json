{
  "name": "@nova/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "dotenv -e ../../.env -o -- prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "push": "dotenv -e ../../.env -o -- prisma db push",
    "studio": "dotenv -e ../../.env -o -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.19.0",
    "typescript": "^5.6.3"
  }
}
